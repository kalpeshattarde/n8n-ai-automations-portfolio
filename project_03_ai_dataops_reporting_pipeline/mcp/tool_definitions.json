{
  "tools": [
    {
      "name": "generate_kpi_summary",
      "description": "Generate KPI summary from cleaned sales orders.",
      "input_schema": {
        "type": "object",
        "properties": {
          "report_date": {"type": "string"},
          "date_from": {"type": "string"},
          "date_to": {"type": "string"}
        }
      }
    },
    {
      "name": "store_kpi_report",
      "description": "Store a validated KPI report for BI consumption.",
      "input_schema": {
        "type": "object",
        "required": ["report_date", "report_type", "report_payload"],
        "properties": {
          "report_date": {"type": "string"},
          "report_type": {"type": "string"},
          "report_payload": {"type": "object"}
        }
      }
    },
    {
      "name": "log_workflow_error",
      "description": "Log DataOps workflow failures.",
      "input_schema": {
        "type": "object",
        "required": ["workflow_name", "error_message"],
        "properties": {
          "workflow_name": {"type": "string"},
          "node_name": {"type": "string"},
          "error_message": {"type": "string"}
        }
      }
    }
  ]
}

