{
  "tools": [
    {
      "name": "create_lead",
      "description": "Create a CRM lead after consent and required-field validation.",
      "input_schema": {
        "type": "object",
        "required": ["full_name", "company_name", "consent"],
        "properties": {
          "full_name": {"type": "string"},
          "work_email": {"type": "string"},
          "company_name": {"type": "string"},
          "consent": {"type": "boolean"},
          "source_record_id": {"type": "string"}
        }
      }
    },
    {
      "name": "update_lead_status",
      "description": "Update a lead status and write a lead event.",
      "input_schema": {
        "type": "object",
        "required": ["lead_id", "status", "event_type"],
        "properties": {
          "lead_id": {"type": "string"},
          "status": {"type": "string"},
          "event_type": {"type": "string"},
          "event_payload": {"type": "object"}
        }
      }
    },
    {
      "name": "create_approval_task",
      "description": "Queue human approval for a lead follow-up.",
      "input_schema": {
        "type": "object",
        "required": ["approver_email", "approval_payload"],
        "properties": {
          "approver_email": {"type": "string"},
          "approval_payload": {"type": "object"}
        }
      }
    },
    {
      "name": "log_workflow_error",
      "description": "Log workflow or node failure details.",
      "input_schema": {
        "type": "object",
        "required": ["workflow_name", "error_message"],
        "properties": {
          "workflow_name": {"type": "string"},
          "node_name": {"type": "string"},
          "error_message": {"type": "string"}
        }
      }
    }
  ]
}

