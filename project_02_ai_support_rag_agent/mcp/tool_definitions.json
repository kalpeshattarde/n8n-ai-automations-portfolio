{
  "tools": [
    {
      "name": "create_support_ticket",
      "description": "Create a support ticket from a validated Gmail message.",
      "input_schema": {
        "type": "object",
        "required": ["subject", "message"],
        "properties": {
          "external_ticket_id": {"type": "string"},
          "customer_email": {"type": "string"},
          "subject": {"type": "string"},
          "message": {"type": "string"},
          "priority": {"type": "string"}
        }
      }
    },
    {
      "name": "search_knowledge_base",
      "description": "Return approved KB snippets for support RAG.",
      "input_schema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {"type": "string"},
          "max_results": {"type": "integer"}
        }
      }
    },
    {
      "name": "create_approval_task",
      "description": "Queue human approval for a support reply.",
      "input_schema": {
        "type": "object",
        "required": ["approver_email", "approval_payload"],
        "properties": {
          "approver_email": {"type": "string"},
          "approval_payload": {"type": "object"}
        }
      }
    },
    {
      "name": "log_workflow_error",
      "description": "Log support workflow failures.",
      "input_schema": {
        "type": "object",
        "required": ["workflow_name", "error_message"],
        "properties": {
          "workflow_name": {"type": "string"},
          "node_name": {"type": "string"},
          "error_message": {"type": "string"}
        }
      }
    }
  ]
}

