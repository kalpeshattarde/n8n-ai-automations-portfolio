# Mock mode does not require any of these values.
# Real Integration Mode uses placeholders only. Do not commit real secrets.

# n8n runtime
N8N_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=replace_with_private_value_outside_git
N8N_WEBHOOK_BASE_URL=https://your-n8n-domain.example
N8N_ERROR_WORKFLOW_ID=replace_with_global_error_workflow_id

# OpenRouter LLM API
OPENROUTER_API_KEY=replace_with_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://github.com/yourname/akceleratehq-ai-automation-portfolio
OPENROUTER_APP_NAME=AKcelerateHQ AI Automation Portfolio

# PostgreSQL local or managed database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akcelerate_automation
POSTGRES_USER=akcelerate_app
POSTGRES_PASSWORD=replace_with_local_or_managed_db_password
DATABASE_URL=postgresql://akcelerate_app:replace_with_password@localhost:5432/akcelerate_automation

# Google Workspace OAuth placeholders
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback
GOOGLE_FORMS_RESPONSE_SHEET_ID=replace_with_sheet_id
GOOGLE_LEADS_SHEET_NAME=Leads
GOOGLE_SUPPORT_LABEL=AI-Support-Intake
GOOGLE_REPORTING_SHEET_ID=replace_with_reporting_sheet_id
GOOGLE_CALENDAR_ID=primary

# Gmail and reporting recipients
GMAIL_SENDER=automation@yourdomain.example
REVOPS_MANAGER_EMAIL=manager@yourdomain.example
SUPPORT_REVIEWER_EMAIL=support-reviewer@yourdomain.example
SUPPORT_MANAGER_EMAIL=support-manager@yourdomain.example
DATAOPS_STAKEHOLDER_EMAIL=ops-lead@yourdomain.example
WORKFLOW_ALERT_EMAIL=automation-alerts@yourdomain.example

# Power BI integration placeholders
POWER_BI_TENANT_ID=replace_with_azure_tenant_id
POWER_BI_CLIENT_ID=replace_with_power_bi_app_client_id
POWER_BI_CLIENT_SECRET=replace_with_power_bi_app_secret
POWER_BI_WORKSPACE_ID=replace_with_workspace_id
POWER_BI_DATASET_ID=replace_with_dataset_id

# Optional MCP server settings
MCP_SERVER_URL=http://localhost:8080/mcp
MCP_TOOL_AUTH_TOKEN=replace_with_internal_tool_token
